# Copy this file to .env before running docker compose.

DEPLOYER_API_PORT=8100
DEPLOYER_WEB_PORT=3000

# Use the same value for frontend and backend when API key protection is wanted.
DEPLOYER_WEB_API_KEY=replace-with-a-long-random-value
NEXT_PUBLIC_DEPLOYER_API_KEY=replace-with-a-long-random-value

# Browser-visible URL used by the Next.js client. For a remote Linux host,
# replace localhost with the host IP address or DNS name.
NEXT_PUBLIC_DEPLOYER_API_URL=http://localhost:8100

# Backend CORS origins. Use the browser origin, or * only on a trusted network.
DEPLOYER_WEB_CORS_ORIGINS=http://localhost:3000

# Host paths mounted into the API container.
HOST_HOME_DIR=${HOME}
OCI_CONFIG_DIR=${HOME}/.oci
DOCKER_CONFIG_DIR=${HOME}/.docker
DOCKER_SOCKET=/var/run/docker.sock

# OCI defaults used by the CLI inside the API container.
OCI_CLI_AUTH=api_key
OCI_CLI_PROFILE=DEFAULT
